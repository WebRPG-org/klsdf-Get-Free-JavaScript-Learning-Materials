{"id":2,"name":"EV002","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":2,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":true,"variableValue":1},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",7,0,2]},{"code":401,"indent":0,"parameters":["那个！！！请您留步！！！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（什么声音？我在这附近可没有熟人啊。）"]},{"code":241,"indent":0,"parameters":[{"name":"萤雪","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"萤雪-伤心",0,0,-300,0,100,100,255,0]},{"code":232,"indent":0,"parameters":[1,0,0,0,0,0,100,100,255,0,60,true]},{"code":101,"indent":0,"parameters":["",7,0,2]},{"code":401,"indent":0,"parameters":["\\n<???>请，请问！前端学院在哪里啊！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你看到一个穿着旗袍的少女，精致的面孔和服饰让你感觉"]},{"code":401,"indent":0,"parameters":["仿佛是来自另一个世界。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>你面前这个就是前端学院。"]},{"code":235,"indent":0,"parameters":[1]},{"code":231,"indent":0,"parameters":[1,"萤雪-惊讶",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",5,0,2]},{"code":401,"indent":0,"parameters":["\\n<???>欸！！！您就是前端学院啊！"]},{"code":101,"indent":0,"parameters":["",1,0,2]},{"code":401,"indent":0,"parameters":["\\n<???>按道理来说，前端学院不是一个建筑物吗？没想"]},{"code":401,"indent":0,"parameters":["到居然是一个人！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>，，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["（这女生真的不要紧嘛？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["（而且为什么还穿着这么正式的衣服？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>总之你先回头"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<???>嗯"]},{"code":235,"indent":0,"parameters":[1]},{"code":231,"indent":0,"parameters":[1,"萤雪-生气",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["然后呢？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["然后你就看到学校了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>欸？这里就是前端学院吗？我记得是会更大一些来着？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>哎呀，没有什么，是我失言了。"]},{"code":401,"indent":0,"parameters":["看来地图所标注的没有问题呢！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>什么地图？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你看到她拿出来一张世界地图。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["，，，，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>也真亏你能找到这里，，话说这么小的字，你怎末"]},{"code":401,"indent":0,"parameters":["看得清楚的？"]},{"code":231,"indent":0,"parameters":[1,"萤雪-微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>少女的直觉啦~直觉。"]},{"code":101,"indent":0,"parameters":["",3,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（女孩子是这么神秘的生物吗？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>额，先不提这个。既然你来学校，那你也是这个学校的"]},{"code":401,"indent":0,"parameters":["学生喽？"]},{"code":231,"indent":0,"parameters":[1,"萤雪-闭目微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<萤雪>正是！小女子有幸考上了JavaScript系。您呢？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>真巧，我也是JavaScript系的。"]},{"code":231,"indent":0,"parameters":[1,"萤雪-微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<萤雪>哎呀！真是太幸运了！"]},{"code":401,"indent":0,"parameters":["小女子叫做萤雪，之后请多指教！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>嗯嗯，请多指教了！"]},{"code":102,"indent":0,"parameters":[["非常不礼貌的擅自和她握手","礼貌的和她微微鞠躬"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"非常不礼貌的擅自和她握手"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["你伸出手去去和她握手。但是她似乎没有动。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["于是你伸了伸手，拉住了她的手。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["但是刚刚摸到，就感到那双温暖柔软的小手猛然收了回去。"]},{"code":231,"indent":1,"parameters":[1,"萤雪-惊讶",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",3,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>呀！"]},{"code":101,"indent":1,"parameters":["",3,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>您怎末搞的！没想到真的选择来摸我的手吗？"]},{"code":231,"indent":1,"parameters":[1,"萤雪-生气",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",3,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>不可以这样哦！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>这也太失礼了！男女授受不亲！"]},{"code":401,"indent":1,"parameters":["怎么可以突然牵女孩子的手！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>随便牵手会怀孕的！"]},{"code":231,"indent":1,"parameters":[1,"萤雪-坏笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>虽然是有这个选项啦，但是不可以！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>啊，我的意思是。我不知道什么选项。"]},{"code":401,"indent":1,"parameters":["反正，这样随便和我握手是不对的！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["，，，，，，"]},{"code":101,"indent":1,"parameters":["",0,