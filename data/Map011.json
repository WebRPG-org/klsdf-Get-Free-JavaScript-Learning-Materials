0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["虽然你的困意仍然没有消除。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["但是你还是努力睁开了眼"]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>为什么我会定闹钟呢？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你仔细在脑海中搜寻着答案。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["昨天我晚上熬夜打了游戏，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["这是因为，我马上要到新的学校去，所以兴奋的睡不着。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["这就是说，今天就是开学的第一天。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>哎呀！几点了！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你一下子跳起来。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["闹钟显示，现在不过7点钟"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>吓死我了。。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["开学典礼的时间是9点，家里离学校很近。"]},{"code":401,"indent":0,"parameters":["再睡一会也来得及。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["于是你躺到床上，打算小睡片刻。"]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["zzzzzz"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["多么美好的一天"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["舒适的被窝，温暖的阳光"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["真想这样睡下去，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["除非，待会的开学典礼，否则没有什么东西能干扰你的睡眠"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["，，，，欸，开学典礼？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["几点了。"]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["天！已经8点50了！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>快迟到了！！！"]},{"code":201,"indent":0,"parameters":[0,7,7,10,0,0]},{"code":201,"indent":0,"parameters":[0,13,9,9,0,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>哇啊！"]},{"code":231,"indent":0,"parameters":[1,"林玲-吃惊",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？>欸？"]},{"code":241,"indent":0,"parameters":[{"name":"软萌的小猫猫","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":0,"parameters":[{"name":"Blow1","volume":90,"pitch":100,"pan":0}]},{"code":235,"indent":0,"parameters":[1]},{"code":224,"indent":0,"parameters":[[255,255,255,170],60,true]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>哇哇哇哇哇！"]},{"code":231,"indent":0,"parameters":[1,"CG林玲摔倒5",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>对，对不起！！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>你没事吧！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>实在对不起！我上课快迟到了！所以就着急赶路了！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>没没，事。老夫，还没有这么容易死，，噗"]},{"code":231,"indent":0,"parameters":[1,"CG林玲摔倒4",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>喷，喷血了！！得，，得赶紧打，打120！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>那边的少年哟。。过来。"]},{"code":231,"indent":0,"parameters":[1,"CG林玲摔倒3",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>在，在！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>在老夫死之前，有最后一个遗言。这是一个惊天的"]},{"code":401,"indent":0,"parameters":["秘密。你要听好了。。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>是！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>其实，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>这不是血，，其实是番茄汁啦。哈哈哈哈哈哈哈。"]},{"code":231,"indent":0,"parameters":[1,"林玲-调皮",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>，，，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>欸？怎么感觉你并不是很惊讶？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>老夫可不是这么小心眼的人。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>这么大的番茄味，很远就闻到了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>哎呀，暴露了呢。欸嘿~"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>不过刚刚撞到你真是不好意思！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>小伙子年轻气盛嘛，能理解的。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>老夫可不是这么小心眼的人。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>不过，老夫能感觉出来哦。你是和我同类类型的"]},{"code":401,"indent":0,"parameters":["替身使者呢~"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>什么？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>我们都被幽灵缠身了，所以每天早上都会被迫"]},{"code":401,"indent":0,"parameters":["赖床，之后在上课时间，被迫去电玩城无意义地消耗人生。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>我可没有打算在开学典礼打游戏，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>是吗？真是残念。看来你的替身还没有觉醒。"]},{"code":401,"indent":0,"parameters":["等觉醒之后，你就不得不接受这无尽的痛苦的诅咒了！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>那真希望我不会觉醒，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>好吧，那我先去接受诅咒了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>对了，跟老夫相撞也算是有缘分。"]},{"code":401,"indent":0,"parameters":["我叫林玲，以后有事找我可以去电玩城哦~"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>那我走了，拜拜！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>喂，也是前端学院的学生吗？你不打算去开学典礼吗？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>早上的时间这么珍贵，怎么可以用来浪费在这种"]},{"code":401,"indent":0,"parameters":["东西上面！不如来跟老夫一起去电玩城啊。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>今天破例请你一个小时也不是不可以，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>不不不，还是算了。。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>是吗？看来你还没有意识到这个世界的残酷啊。"]},{"code":401,"indent":0,"parameters":["嘛，以后你就会懂了。"]},{"code":231,"indent":0,"parameters":[1,"林玲-坏笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>躺平才是真正的解脱啊！"]},{"code":231,"indent":0,"parameters":[1,"林玲-调皮",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>好了好了，我走了，以后想找我可以去电玩城啊。"]},{"code":242,"indent":0,"parameters":[10]},{"code":235,"indent":0,"parameters":[1]},{"code":117,"inde