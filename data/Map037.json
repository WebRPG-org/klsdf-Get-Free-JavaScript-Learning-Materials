,{"code":241,"indent":1,"parameters":[{"name":"萤雪","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["夜晚的公园非常安静，只有早蝉偶尔叫上几声，"]},{"code":401,"indent":1,"parameters":["打破这孤寂的夜晚。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["你闭上眼睛默默享受这着夜晚。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<？？>哎呀，你来这里做什么啊？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["回头望去，你看到一个身着旗袍的少女。"]},{"code":231,"indent":1,"parameters":[1,"萤雪-微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>你也来这里冥想的吗？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>公园的景色很好呢，有一种放松的感觉。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["她来到你身边"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>来一起坐一会吗？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>啊，对了！"]},{"code":231,"indent":1,"parameters":[1,"萤雪-坏笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>你可不要趁着夜色，悄悄的朝我靠近！！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>然后装作什么都不知道的样子和我挨在一起！"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>我可不是那种好攻略的女孩子。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<你>你的脑补能力未免太强了。"]},{"code":231,"indent":1,"parameters":[1,"CG萤雪在公园2",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["于是带着一丝犹豫，她还是坐到了你身边"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["周围又恢复了寂静"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["你稍微有点紧张。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>你说，天上有多少颗星星啊？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<你>应该有50万5千零5颗。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>你是怎末知道的怎么确切的？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<你>不信的话你可以数啊~"]},{"code":231,"indent":1,"parameters":[1,"CG萤雪在公园",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>真是坏心眼，"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>，，，，"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>真好啊"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>像这样平静无趣的日常生活，"]},{"code":401,"indent":1,"parameters":["是多么的美好。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>像要是这一刻能永远持续下去该有多好啊。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<萤雪>好了，时间也不早了，我该回去了，再见喽"]},{"code":235,"indent":1,"parameters":[1]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["萤雪好感度+10"]},{"code":355,"indent":1,"parameters":["DataController.增减萤雪好感度(10)"]},{"code":242,"indent":1,"parameters":[10]},{"code":117,"indent":1,"parameters":[1]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"否"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":false},{"conditions":{"actorI