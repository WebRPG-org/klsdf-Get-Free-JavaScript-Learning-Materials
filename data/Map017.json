}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":false},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":true,"variableValue":4},"directionFix":false,"image":{"tileId":0,"characterName":"!Flame","direction":2,"pattern":1,"characterIndex":6},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["一个售卖速食食品的商铺，你平时都是来这里买早餐"]},{"code":401,"indent":0,"parameters":["，午餐，以及晚餐。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（怎么感觉，我天天都是过着这样肥宅的生活呢？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>老板，我要一个汉堡。要双倍的汉堡肉。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你和周围的群众都好奇地望过去。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>再加双倍的芝士片。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["老板也抬起头望了一下。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["小姑娘怎么吃这么多啊？就算我家汉堡好吃也不能一顿吃太多"]},{"code":401,"indent":0,"parameters":["啊！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>我是今年前端学院的第二名，想吃顿好的。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["周围传来好奇，羡慕的目光。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>要是我考试的时候没有发烧的话，我才是第一名！"]},{"code":401,"indent":0,"parameters":["萤雪的身份本身就有很多加分项，理论上我的分数才是"]},{"code":401,"indent":0,"parameters":["最高的。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>本来应该是我上台演讲的！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["人群渐渐议论起来。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（好奇怪的女孩子啊）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["老板笑了一下"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<老板>人生就是这样嘛，多送你一瓶饮料吧，希望你以后"]},{"code":401,"indent":0,"parameters":["多多努力！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>，，谢谢。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["之后那个女生回过头，你和她无意中对上了眼。"]},{"code":231,"indent":0,"parameters":[1,"小芳-沉默",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>，，，，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>你你，你是萤雪旁边那个？！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>喂，跟我稍稍过来一下！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（完了，和奇怪的人扯上关系了。）"]},{"code":201,"indent":0,"parameters":[0,12,11,10,0,0]},{"code":230,"indent":0,"parameters":[60]},{"code":201,"indent":0,"parameters":[0,37,8,10,0,0]},{"code":230,"indent":0,"parameters":[60]},{"code":241,"indent":0,"parameters":[{"name":"独自等待","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>好了，就这这里说吧。"]},{"code":231,"indent":0,"parameters":[1,"小芳-沉默",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>我给你100元，你不要把我刚才说的告诉萤雪。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>不，我不会收的，也不会告诉她的。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>我可不是这种爱告状的人。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>好吧，谢谢你。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>我把汉堡分你一半吧。刚才都怪我把你拉走。"]},{"code":401,"indent":0,"parameters":["你都没有买上。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>你还知道啊，，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<？？？>对不起，给你。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你拿起她的汉堡开始吃起来。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["她也开始吃起来。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你们两个之间只有不断的咀嚼声传来。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>我叫小芳。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>欸？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>所以你和萤雪是什么关系？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>啊？没什么关系？今天偶然遇到了而已。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>那就好。她那种人，怎么可能有朋友。"]},{"code":231,"indent":0,"parameters":[1,"小芳-生气",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>依靠自己的权力，把自己送进这个学校。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>而我这种真正的天才却被埋没！"]},{"code":231,"indent":0,"parameters":[1,"小芳-沉默",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>，，，不好意思，是我失礼了。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<小芳>对着刚认识的人说这些是我的不对。"]},{"code":102,"indent":0,"parameters":[["原谅她","批评她"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"原谅她"]},{"code":231,"indent":1,"parameters":[1,"小芳-盯着",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>，，，"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>谢谢你，你是个好人。"]},{"code":231,"indent":1,"parameters":[1,"小芳-微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>我现在开始赶紧世界恢复正常了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>之前总有人莫名其妙地批判我，我明明已经很努力了。"]},{"code":401,"indent":1,"parameters":["却没有人来关心我。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>哎呀，说多了。总之，谢谢你。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["小芳好感度+10"]},{"code":355,"indent":1,"parameters":["DataController.增减小芳好感度(10)"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"批评她"]},{"code":231,"indent":1,"parameters":[1,"小芳-沉默",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>，，，"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>对不起。请把我剩下的饮料也喝了吧。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["接着她拿起瓶子强行塞到你嘴边。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<你>停停停，这个可乐是你喝过的吧。"]},{"code":401,"indent":1,"parameters":["我再喝不就相当于，，间接亲吻吗？"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>，，，没想到。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<小芳>我以为我这种绝世美少女的建议是不会被拒绝的。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<你>除了我这样的君子，我想一般人都拒绝不了吧。"]},{"code":231,"indent":1,"parameters":[1,"小芳-微笑",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":