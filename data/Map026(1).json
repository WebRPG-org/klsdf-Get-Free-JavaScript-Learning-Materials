,"indent":0,"parameters":["\\n<映月>（可恶，居然是天降系！）"]},{"code":231,"indent":0,"parameters":[1,"林玲-微笑",0,0,-50,45,80,80,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>那么，老夫先走啦~一日之计在于晨嘛。"]},{"code":231,"indent":0,"parameters":[2,"映月立绘-微笑",0,0,350,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<映月>嗯嗯，那再见啦。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>话说你也是前端学院的吗？顺路的话可以一起走啊？"]},{"code":231,"indent":0,"parameters":[1,"林玲-坏笑",0,0,-50,45,80,80,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<林玲>哎呀呀，老夫可不能把美好的青春耗费在这里。"]},{"code":401,"indent":0,"parameters":["那么先走啦~~"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["之后，飞快地离开了这里。"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>真是奇怪的人，那么咱们也走吧！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["说着，你去拉映月的手，但是立刻就被甩开了。"]},{"code":231,"indent":0,"parameters":[2,"映月立绘-生气",0,0,350,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<映月>老哥太过分了！！！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<映月>明明才见第一面，就想去攻略她了吗？"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>和邻居处好关系很正常啦，好啦好啦。以后我不去"]},{"code":401,"indent":0,"parameters":["搭理她了，这样好了吗？"]},{"code":231,"indent":0,"parameters":[2,"映月立绘-脸红",0,0,350,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<映月>我，我又没说不让你见她，你找不找她和我没关系。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<映月>啊啊啊，好了好了，不说这个了。老哥以后要多"]},{"code":401,"indent":0,"parameters":["洁身自好！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["说着拉起你的手快速离开了这里。"]},{"code":235,"indent":0,"parameters":[2]},{"code":117,"indent":0,"parameters":[2]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":2,"y":8},
