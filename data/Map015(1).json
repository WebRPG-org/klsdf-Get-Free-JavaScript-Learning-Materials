{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":true,"variableValue":3},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":241,"indent":0,"parameters":[{"name":"欢乐瞬间","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["到了礼堂之后，才发现今年的新生人数也并不少。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>看来就算是名校，每年考进来的人也不少啊（（"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["由于开学典礼是按照班级名次来就坐的，所以刚刚班上看到的"]},{"code":401,"indent":0,"parameters":["几个面孔都坐到了你的旁边。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["可是，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（萤雪的位置怎末空着？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（是去上厕所了吗？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（刚才老师讲话的时候她不在，有可能是没听到吧？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["“咳咳，那么开学典礼正式开始”"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["一个声音打断了你的思考。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你抬头望去，一个年迈但是肥胖的中年大叔正站在主席台上。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（这个校长未免过于刻板形象了。）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["咳咳，首先强调一下纪律问题。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\C[18]学校并不强制上课，但是会有成绩考核。学期末"]},{"code":401,"indent":0,"parameters":["结束后，第10天时，如果没有参加考试，并且知识低于"]},{"code":401,"indent":0,"parameters":["30会被开除。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["不过我想咱们学校应该不会有这种人吧。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\C[18]另外，上课时间是每天的上午和下午。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["之后再强调一下大家的作风问题，，"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["无聊的讲话让你昏昏欲睡，况且今天一大早就被叫醒。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["就在你马上要进入梦乡的时候，会场突然骚动起来"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你睁开眼，看到一头黑色的长发，从你身边飘过。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["拥有那样优雅的姿态的人，毫无疑问只有一个人。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>萤雪！"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["接着，你看到她缓缓走到主席台上。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<校长>好，那么我们欢迎今年的学生代表，萤雪同学，"]},{"code":401,"indent":0,"parameters":["代表新生讲话。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你望向萤雪。她正自信又冷静地念着发言稿。"]},{"code":231,"indent":0,"parameters":[1,"CG萤雪演讲",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（没想到那个呆呆的女生居然是学生代表。）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["不知道是不是察觉到了你的目光，她望向你轻轻微笑了一下。"]},{"code":231,"indent":0,"parameters":[1,"CG萤雪演讲2",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["你心脏狠狠地跳动了一下。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["美少女可真是一种有杀伤力的生物呢。"]},{"code":231,"indent":0,"parameters":[1,"CG萤雪演讲",0,0,0,0,100,100,255,0]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["之后，萤雪就转了过去。继续发表着演讲。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["很快，开学典礼结束了。"]},{"code":235,"indent":0,"parameters":[1]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["因为是开学第一天，所以也不用上课。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（待会去商业街把午饭一买，顺便再买一个烧饼吧。"]},{"code":401,"indent":0,"parameters":["晚上就着泡面就能凑合一顿饭了。）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>（话说萤雪演讲结束后就没有看到她了，她一个人"]},{"code":401,"indent":0,"parameters":["没事吗？不会在学校里面迷路了吧？）"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<你>，，这么说起来，我为什么要这么关心才认识一天的"]},{"code":401,"indent":0,"parameters":["同学。还是先去吃饭吧。"]},{"code":242,"indent":0,"parameters":[10]},{"code":117,"indent":0,"parameters":[1]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":0,"y":0},
